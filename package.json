{
  "name": "home-family-fund",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "sh prisma/seed.sh",
    "db:seed:e2e": "SEED_SQL_FILE=prisma/seed.e2e.sql sh prisma/seed.sh",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "lint": "prisma generate && eslint .",
    "type-check": "prisma generate && tsc --noEmit",
    "test": "prisma generate && vitest run",
    "test:watch": "vitest",
    "test:e2e": "sh e2e/setup-db.sh && sh e2e/run-playwright.sh"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "latest",
    "better-auth": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "latest",
    "lucide-react": "^1.17.0",
    "next": "latest",
    "radix-ui": "^1.5.0",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "latest",
    "tw-animate-css": "^1.3.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "eslint": "^9.39.1",
    "eslint-config-next": "latest",
    "jsdom": "latest",
    "prisma": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
