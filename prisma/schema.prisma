generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MemberStatus {
  invited
  active
  disabled
}

enum MemberRole {
  admin
  finance_manager
  general_member
}

enum MemberCapability {
  manage_categories
  manage_recurring
}

enum MemberInvitationStatus {
  pending
  accepted
  revoked
}

enum CategoryType {
  income
  expense
}

enum CategoryStatus {
  active
  archived
}

enum LedgerRecordType {
  income
  expense
}

enum LedgerRecordStatus {
  active
  voided
}

enum PaymentSource {
  fund
  member
}

enum ReimbursementStatus {
  not_applicable
  not_refundable
  refundable
  reimbursed
}

enum RecurringPostingMode {
  immediate
  reminder
}

enum RecurringOccurrenceStatus {
  pending
  posted
  skipped
}

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              Member[]
  memberInvitations    MemberInvitation[]
  categories           Category[]
  ledgerRecords        LedgerRecord[]
  recurringRules       RecurringRule[]
  recurringOccurrences RecurringOccurrence[]
  reimbursementBatches ReimbursementBatch[]
}

model Member {
  id                 String       @id @default(cuid())
  householdId        String
  displayName        String
  avatarUrl          String?
  googleAccountEmail String?      @unique
  googleSubject      String?      @unique
  status             MemberStatus @default(invited)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Restrict)

  roles                MemberRoleAssignment[]
  capabilities         MemberCapabilityAssignment[]
  createdLedgerRecords LedgerRecord[]               @relation("LedgerRecordCreator")
  sourcedIncomeRecords LedgerRecord[]               @relation("IncomeSourceMember")
  paidExpenseRecords   LedgerRecord[]               @relation("ExpensePayerMember")
  reimbursementBatches ReimbursementBatch[]         @relation("ReimbursementBatchActor")
  createdInvitations   MemberInvitation[]           @relation("MemberInvitationCreator")
  invitations          MemberInvitation[]           @relation("MemberInvitationTarget")

  @@index([householdId])
}

model MemberInvitation {
  id                 String                 @id @default(cuid())
  householdId        String
  memberId           String?
  googleAccountEmail String?
  tokenHash          String                 @unique
  previewToken       String?
  status             MemberInvitationStatus @default(pending)
  expiresAt          DateTime
  acceptedAt         DateTime?
  createdById        String
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Restrict)
  member    Member?   @relation("MemberInvitationTarget", fields: [memberId], references: [id], onDelete: SetNull)
  createdBy Member    @relation("MemberInvitationCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([householdId, status, expiresAt])
  @@index([memberId, status])
  @@index([googleAccountEmail, status])
}

model MemberRoleAssignment {
  memberId  String
  role      MemberRole
  createdAt DateTime   @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([memberId, role])
}

model MemberCapabilityAssignment {
  memberId   String
  capability MemberCapability
  createdAt  DateTime         @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([memberId, capability])
}

model Category {
  id          String         @id @default(cuid())
  householdId String
  type        CategoryType
  name        String
  color       String         @default("gold")
  icon        String         @default("tags")
  sortOrder   Int            @default(0)
  status      CategoryStatus @default(active)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  household      Household       @relation(fields: [householdId], references: [id], onDelete: Restrict)
  ledgerRecords  LedgerRecord[]
  recurringRules RecurringRule[]

  @@index([householdId, type, name])
  @@index([householdId, type, status])
  @@index([householdId, type, status, sortOrder])
}

model LedgerRecord {
  id                  String              @id @default(cuid())
  householdId         String
  type                LedgerRecordType
  name                String
  amountCents         Int
  occurredOn          DateTime            @db.Date
  categoryId          String
  createdByMemberId   String
  sourceMemberId      String?
  paymentSource       PaymentSource?
  payerMemberId       String?
  reimbursementStatus ReimbursementStatus
  status              LedgerRecordStatus @default(active)
  note                String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  household       Household @relation(fields: [householdId], references: [id], onDelete: Restrict)
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdByMember Member    @relation("LedgerRecordCreator", fields: [createdByMemberId], references: [id], onDelete: Restrict)
  sourceMember    Member?   @relation("IncomeSourceMember", fields: [sourceMemberId], references: [id], onDelete: Restrict)
  payerMember     Member?   @relation("ExpensePayerMember", fields: [payerMemberId], references: [id], onDelete: Restrict)

  recurringOccurrence RecurringOccurrence?
  reimbursementItems  ReimbursementBatchItem[]

  @@index([householdId, occurredOn])
  @@index([householdId, type, occurredOn])
  @@index([householdId, reimbursementStatus, occurredOn])
  @@index([householdId, status, occurredOn])
  @@index([householdId, status, occurredOn, id], map: "LedgerRecord_search_occurred_cursor_idx")
  @@index([householdId, status, type, occurredOn, id], map: "LedgerRecord_search_type_cursor_idx")
  @@index([householdId, status, categoryId, occurredOn, id], map: "LedgerRecord_search_category_cursor_idx")
  @@index([householdId, status, amountCents, occurredOn, id], map: "LedgerRecord_search_amount_cursor_idx")
  @@index([householdId, status, reimbursementStatus, occurredOn])
  @@index([householdId, status, reimbursementStatus, occurredOn, id], map: "LedgerRecord_search_reimbursement_cursor_idx")
  @@index([payerMemberId, reimbursementStatus])
}

model RecurringRule {
  id             String               @id @default(cuid())
  householdId    String
  type           LedgerRecordType
  amountCents    Int
  categoryId     String
  sourceMemberId String?
  paymentSource  PaymentSource?
  payerMemberId  String?
  postingMode    RecurringPostingMode
  dayOfMonth     Int
  note           String?
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  household   Household             @relation(fields: [householdId], references: [id], onDelete: Restrict)
  category    Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  occurrences RecurringOccurrence[]

  @@index([householdId, active])
}

model RecurringOccurrence {
  id              String                    @id @default(cuid())
  householdId     String
  recurringRuleId String
  month           String
  status          RecurringOccurrenceStatus
  ledgerRecordId  String?                   @unique
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  household     Household     @relation(fields: [householdId], references: [id], onDelete: Restrict)
  recurringRule RecurringRule @relation(fields: [recurringRuleId], references: [id], onDelete: Cascade)
  ledgerRecord  LedgerRecord? @relation(fields: [ledgerRecordId], references: [id], onDelete: SetNull)

  @@unique([recurringRuleId, month])
  @@index([householdId, month, status])
}

model ReimbursementBatch {
  id             String   @id @default(cuid())
  householdId    String
  reimbursedById String
  reimbursedAt   DateTime @default(now())
  createdAt      DateTime @default(now())

  household    Household                @relation(fields: [householdId], references: [id], onDelete: Restrict)
  reimbursedBy Member                   @relation("ReimbursementBatchActor", fields: [reimbursedById], references: [id], onDelete: Restrict)
  items        ReimbursementBatchItem[]

  @@index([householdId, reimbursedAt])
}

model ReimbursementBatchItem {
  reimbursementBatchId String
  ledgerRecordId       String

  reimbursementBatch ReimbursementBatch @relation(fields: [reimbursementBatchId], references: [id], onDelete: Cascade)
  ledgerRecord       LedgerRecord       @relation(fields: [ledgerRecordId], references: [id], onDelete: Restrict)

  @@id([reimbursementBatchId, ledgerRecordId])
  @@unique([ledgerRecordId])
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions Session[]
  accounts Account[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime

  @@index([identifier])
}
